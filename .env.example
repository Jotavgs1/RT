# Credenciais do Mercado Livre
# Obtenha em: https://developers.mercadolivre.com.br/
MELI_ACCESS_TOKEN=seu_access_token_aqui
MELI_CLIENT_ID=seu_client_id_aqui
MELI_CLIENT_SECRET=seu_client_secret_aqui

# Intervalo de coleta em minutos (padrão: 60)
COLLECT_INTERVAL_MINUTES=60

# Habilitar scraping como último recurso (true/false)
ENABLE_SCRAPING=false

# Porta do servidor (padrão: 3000)
PORT=3000
